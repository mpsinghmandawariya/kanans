      "requirements": [
        "Valid passport",
        "Letter of acceptance from DL",
        "Proof of financial support",
        "Passport-sized photos",
        "Immigration medical examination",
        "Police certificate"
      ],
      "process": [
        "Apply to a designated learning institution",
        "Receive letter of acceptance",
        "Gather required documents",
        "Apply for study permit online",
        "Attend biometric appointment",
        "Wait for processing"
      ],
      "processing_time": "8-12 weeks"
    },
    "uk": {
      "name": "UK Student Visa (Tier 4)",
      "description": "The Student Visa allows you to study at a UK university.",
      "requirements": [
        "Valid passport",
        "Confirmation of Acceptance for Studies (CAS)",
        "Proof of English language proficiency",
        "Proof of financial support",
        "Tuberculosis test results"
      ],
      "process": [
        "Receive CAS from your UK university",
        "Gather required documents",
        "Apply online for student visa",
        "Pay immigration health surcharge",
        "Attend biometric appointment",
        "Wait for visa decision"
      ],
      "processing_time": "3-8 weeks"
    },
    "australia": {
      "name": "Australia Student Visa (Subclass 500)",
      "description": "The Subclass 500 visa allows you to study full-time in Australia.",
      "requirements": [
        "Valid passport",
        "Confirmation of Enrolment (COE)",
        "Genuine Student (GS) requirement",
        "Overseas Student Health Cover (OSHC)",
        "Proof of financial capacity",
        "English language proficiency"
      ],
      "process": [
        "Get enrolled at an Australian institution",
        "Receive your Confirmation of Enrolment (COE)",
        "Purchase OSHC",
        "Apply for visa online",
        "Provide biometrics",
        "Wait for visa grant"
      ],
      "processing_time": "4-12 weeks"
    }
